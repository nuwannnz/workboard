{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WorkBoard",
  "version": "0.0.0",
  "identifier": "com.workboard.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:4200",
    "beforeDevCommand": "vite --port 4200",
    "beforeBuildCommand": "vite build"
  },
  "app": {
    "windows": [
      {
        "title": "WorkBoard",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "minWidth": 480,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.png"]
  }
}
