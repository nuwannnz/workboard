# Frontend build-time configuration (Vite). Copy to `apps/frontend/.env.local` for
# local development. Values are sourced from the CDK stack outputs — NEVER commit real
# values (FR-013). Only `VITE_`-prefixed vars are exposed to the bundle.

# API base URL. In AWS this is the CDK `ApiBaseUrl` output. For fully-local dev it is `/api`,
# which the Vite dev server proxies to the local backend (avoids browser CORS).
VITE_API_BASE_URL=/api

# --- Auth (Cognito) ---
# UserPoolId / public app client id. In AWS these come from the CDK stack outputs; for
# fully-local dev they are the cognito-local IDs, filled automatically by `npm run local`.
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_CLIENT_ID=

# Local Cognito emulator endpoint. When set, the app talks to cognito-local (via the Vite
# `/cognito` proxy) using USER_PASSWORD_AUTH instead of real Cognito SRP. Leave EMPTY to use
# real AWS Cognito (SRP). Local value: /cognito
VITE_COGNITO_ENDPOINT=/cognito
