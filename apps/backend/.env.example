# Backend runtime configuration. Copy to `apps/backend/.env` for local development.
# Nothing sensitive is committed; values come from the environment / CDK stack outputs.

# AWS region used by the backend + SDK clients
AWS_REGION=us-east-1
# DynamoDB single-table name (CDK `TableName` output in AWS)
WORKBOARD_TABLE_NAME=WorkBoard
# For local development against DynamoDB Local (docker-compose in apps/backend)
DYNAMODB_ENDPOINT=http://localhost:8000
# Local Express port
PORT=3000

# --- Auth (Cognito) ---
# CDK `UserPoolId` output — required by the resend-verification helper and local verifier.
# For fully-local dev these are the cognito-local IDs, filled automatically by `npm run local`.
COGNITO_USER_POOL_ID=
# CDK `UserPoolClientId` output — the public app client id
COGNITO_CLIENT_ID=
# Local-dev fallback: when "true", the authenticate middleware verifies the id token
# in-process with aws-jwt-verify (there is no API Gateway authorizer in front locally).
# Leave unset/false in the deployed Lambda — API Gateway verifies at the edge.
AUTH_LOCAL_VERIFY=true

# --- Local Cognito emulator (cognito-local) — local dev only, filled by `npm run local` ---
# Explicit token issuer + JWKS URI. When both are set the local verifier uses aws-jwt-verify's
# generic JwtRsaVerifier against the emulator instead of real AWS Cognito. Leave BOTH empty to
# verify against a real Cognito user pool. Example values for cognito-local:
#   COGNITO_ISSUER=http://localhost:9229/<localPoolId>
#   COGNITO_JWKS_URI=http://localhost:9229/<localPoolId>/.well-known/jwks.json
COGNITO_ISSUER=
COGNITO_JWKS_URI=
