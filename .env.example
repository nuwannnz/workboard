# WorkBoard environment configuration (example).
# Copy to `.env` for local development. NEVER commit real secrets (FR-017).
# Runtime config is supplied via environment variables / CDK stack outputs;
# nothing sensitive is committed or bundled into the frontend.

# --- Backend ---
# AWS region used by the backend + SDK clients
AWS_REGION=us-east-1
# DynamoDB single-table name (provided by the CDK `infra` stack output in AWS)
WORKBOARD_TABLE_NAME=WorkBoard
# For local development against DynamoDB Local (docker-compose in apps/backend)
DYNAMODB_ENDPOINT=http://localhost:8000
# Dummy credentials for DynamoDB Local only (real creds come from the AWS provider chain)
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local
# Local Express port
PORT=3000

# --- Frontend ---
# API base URL (CDK API Gateway output in AWS; local backend in dev)
VITE_API_BASE_URL=http://localhost:3000

# --- Auth (Cognito, provisioned by CDK; IDs come from stack outputs) ---
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_USER_POOL_CLIENT_ID=
